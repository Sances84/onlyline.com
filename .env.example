# Penguin Clicker API Configuration (SERVER-SIDE ONLY)
# ⚠️  DO NOT commit this file to git. Add to .gitignore.
# Get your own project ID from: https://penguinmod.com/

# Your Penguin Clicker API URL with your own project ID
PENGUIN_CLICKER_API=https://projects.penguinmod.com/api/v1/projects/getproject?projectID=YOUR_PROJECT_ID&requestType=metadata

# Server port (optional)
PORT=3000

# How to set up:
# 1. Create .env.local with your real API URL
# 2. Run: npm install && npm start
# 3. Stats are cached to penguin-stats-cache.json on disk
# 4. Client fetches from /api/penguin-stats endpoint (no API URL exposed!)

# For GitHub Pages deployment, use GitHub Actions secrets:
# Settings → Secrets → New repository secret
# Name: PENGUIN_CLICKER_API
# Value: Your full API URL
